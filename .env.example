# Runtime mode
APP_ENV=local
APP_TIMEZONE=Asia/Ho_Chi_Minh
LOG_SOURCE_MODE=local_folder
LOG_ROOT_PATH=G:\My Drive\8. VNG\07.PYCODE\VNG\AGENT\infra-log-sentinel-demo

# Self-contained runtime demo mode
# Use these values in GreenNode runtime when the agent should create and read its own log folder.
RUNTIME_LOG_BOOTSTRAP_ENABLED=false
DEMO_LOG_BOOTSTRAP_COUNT=16
DEMO_LOG_GENERATOR_ENABLED=false
DEMO_LOG_INTERVAL_SECONDS=30
DEMO_LOG_DOMAIN=all
DEMO_LOG_SEVERITY=abnormal
INCIDENT_LOG_GENERATOR_ENABLED=false
INCIDENT_LOG_INTERVAL_SECONDS=300
RUNTIME_SCHEDULER_ENABLED=false
RUNTIME_SCHEDULER_DRY_RUN=true
RUNTIME_SCHEDULER_MAX_ALERTS=3
RUNTIME_SCHEDULER_MAX_ESCALATIONS=3

# Optional Google Drive API mode for later deployment
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=

# Gmail report sender
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=replace_with_gmail_app_password
REPORT_RECIPIENT_EMAIL=your_email@gmail.com

# Telegram alerts
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_CHAT_ID=replace_with_telegram_chat_id
TELEGRAM_ACK_KEYWORDS=ACK,ack,noted,da nhan,đã nhận
TELEGRAM_CHAT_ENABLED=false
TELEGRAM_CHAT_POLL_INTERVAL_SECONDS=3
TELEGRAM_CHAT_DRY_RUN=false

# Schedule and alert behavior
REPORT_TIME=09:00
REPORT_LOOKBACK_HOURS=24
SCAN_INTERVAL_SECONDS=60
ESCALATION_TIMEOUT_SECONDS=300
SEVERITY_ALERT_LEVELS=warning,error,critical

# LLM / GreenNode MaaS, OpenAI-compatible API
# Fill these to enable ChatGPT-like answers grounded in the current log context.
# Recommended model on GreenNode AIP: MiniMax M2.5.
# Use the model path from GreenNode AIP, not just the display name.
LLM_PROVIDER=greennode
LLM_API_BASE=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=minimax/minimax-m2.5

# Local state
STATE_DB_PATH=data/infra_log_sentinel.sqlite
REPORT_OUTPUT_DIR=reports
